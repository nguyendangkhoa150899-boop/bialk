# Token bot Discord (lấy từ https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# Credentials Vbee (lấy từ studio.vbee.vn)
VBEE_APP_ID=your_vbee_app_id_here
VBEE_API_KEY=your_vbee_jwt_token_here
VBEE_API_URL=https://api.vbee.vn/v1/tts

# Giọng đọc mặc định
TTS_VOICE=hue_male_duyphuong_full_48k-fhg

# Webhook server nhận callback từ Vbee (async mode)
WEBHOOK_PORT=3000
WEBHOOK_PUBLIC_URL=https://your-vps-ip-or-ngrok.com
